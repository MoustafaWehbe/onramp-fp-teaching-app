# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter_kit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=starter_kit
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── OpenAI (optional) ────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Storage / S3 (optional) ──────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
